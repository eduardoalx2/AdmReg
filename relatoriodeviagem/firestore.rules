rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: reports
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - localSaida: string (required)
    //   - localDestino: string (required)
    //   - motivoViagem: string (required)
    //   - role: string
    //   - noRecibo: string
    //   - nomePorExtenso: string
    //   - nomeIgreja: string
    //   - cnpjCod: string
    //   - cidadeUf: string
    //   - data: string (ISO)
    //   - assinatura: string (valdir, edu, none)
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    //
    // Subcollection: reports/{reportId}/expenses
    // Document ID: auto-generated
    // Fields:
    //   - reportId: string (required)
    //   - categoryId: string (required)
    //   - receiptNumber: string
    //   - value: number (required)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // For this app, we'll allow any authenticated user to manage reports
    // In a real multi-user app, we'd add ownership checks.
    // Since the user is the only one using it (likely), we'll keep it simple but authenticated.

    function isValidReport(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.localSaida is string &&
             data.localDestino is string &&
             data.motivoViagem is string;
    }

    function isValidExpense(data) {
      return data.reportId is string &&
             data.categoryId in ['hospedagem', 'alimentacao', 'transporte', 'pedagio', 'combustivel', 'estacionamento'] &&
             data.value is number && data.value >= 0;
    }

    match /reports/{reportId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidReport(request.resource.data);
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid && isValidReport(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;

      match /expenses/{expenseId} {
        // Expenses are protected by the parent report ownership
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/reports/$(reportId)).data.uid == request.auth.uid;
        allow create: if isAuthenticated() && get(/databases/$(database)/documents/reports/$(reportId)).data.uid == request.auth.uid && isValidExpense(request.resource.data);
        allow update: if isAuthenticated() && get(/databases/$(database)/documents/reports/$(reportId)).data.uid == request.auth.uid && isValidExpense(request.resource.data);
        allow delete: if isAuthenticated() && get(/databases/$(database)/documents/reports/$(reportId)).data.uid == request.auth.uid;
      }
    }

    // Support for Dashboard collectionGroup query
    match /{path=**}/expenses/{expenseId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
