rules_version = '2';
// Regras do banco do app de Relatório de Viagem.
// Projeto: gen-lang-client-0821007726 | Database (nomeada): ai-studio-6e8ee6cf-2e0e-4813-8221-70d1cc511c09
// NÃO é o banco do reg655 (regiao655-admin). Deploy feito via Firebase Rules API.
//
// Acesso COMPARTILHADO entre as contas autorizadas (allowlist). As duas contas
// veem/editam os mesmos relatórios; qualquer outra conta Google é bloqueada.
//   gEiATbiJhqZ8Td1uqlwmi6g16h23 = eduardoalx@gmail.com
//   TwjNem78lsMtN6NuXG89JUmlKkl2 = centralieq@gmail.com
service cloud.firestore {
  match /databases/{database}/documents {

    function allowed() {
      return request.auth != null && request.auth.uid in [
        'gEiATbiJhqZ8Td1uqlwmi6g16h23',
        'TwjNem78lsMtN6NuXG89JUmlKkl2'
      ];
    }

    function validReport(d) {
      return d.name is string && d.name.size() > 0 && d.name.size() < 200
        && d.uid is string
        && d.localSaida is string && d.localDestino is string && d.motivoViagem is string
        && d.total is number
        && d.locked is bool;
    }
    function validExpense(d) {
      return d.uid is string
        && d.reportId is string
        && d.categoryId in ['hospedagem','alimentacao','transporte','pedagio','combustivel','estacionamento']
        && d.value is number && d.value >= 0;
    }

    match /reports/{reportId} {
      allow read, delete: if allowed();
      allow create: if allowed() && validReport(request.resource.data);
      allow update: if allowed() && validReport(request.resource.data);

      match /expenses/{expenseId} {
        allow read, delete: if allowed();
        allow create: if allowed() && validExpense(request.resource.data);
        allow update: if allowed() && validExpense(request.resource.data);
      }
    }

    // Dashboard usa collectionGroup('expenses')
    match /{path=**}/expenses/{expenseId} {
      allow read: if allowed();
    }

    match /users/{userId} {
      allow read, write: if allowed();
    }
  }
}
